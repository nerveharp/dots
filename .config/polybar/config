[colors]
background = #000000
background-alt = #000
foreground = #FFF
foreground-alt = #FFF
primary = #000
secondary = #000
alert = #ff00dd

[bar/example]
width = 100%
height = 24
offset-x = 0%
offset-y = 0px
radius = 0px
fixed-center = true
background = ${colors.background}
foreground = ${colors.foreground}
line-size = 0
line-color = #FFF
border-size = 0
border-color = #FFF
padding-left = 0
padding-right = 2
module-margin-left = 0
module-margin-right = 4
font-0 = Terminus:pixelsize=8;1
modules-left = 
modules-center = 
modules-right = battery1 battery0 temperature date 
tray-position = right
tray-padding = 4 
cursor-click = pointer
cursor-scroll = ns-resize
enable-ipc = true

[module/filesystem]
type = internal/fs
interval = 25
mount-0 = /
label-mounted = ÔüČ %percentage_used%%
label-unmounted = %mountpoint% not mounted
label-unmounted-foreground = ${colors.foreground-alt}

[module/xbacklight]
type = internal/xbacklight
format = ÔóĚ  <bar>
label =
bar-width = 10 
bar-indicator = 
bar-indicator-foreground = ${colors.foreground}
bar-indicator-font = 2
bar-fill = ÔĪĘ
bar-fill-font = 2
bar-fill-foreground = ${colors.foreground}
bar-empty = Ôõó
bar-empty-font = 2
bar-empty-foreground = ${colors.foreground-alt}

[module/backlight-acpi]
inherit = module/xbacklight
type = internal/backlight
card = intel_backlight

[module/cpu]
type = internal/cpu
interval = 2
format-prefix = "Ô°ö "
label = %percentage:2%%

[module/memory]
type = internal/memory
interval = 2
format-prefix = "Ô¨ô "
format-underline = #4bffdc
label = %percentage_used%%

[module/wlan]
type = internal/network
interface = wlan0
interval = 3.0
format-connected = Ô™®  <label-connected>
format-connected-underline = #9f78e1
label-connected = %essid%
format-disconnected =
;format-disconnected = <label-disconnected>
;format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${colors.foreground-alt}


[module/eth]
type = internal/network
interface = enp0s31f6
interval = 3.0
format-connected-prefix = "ÓÜú "
format-connected-prefix-foreground = ${colors.foreground-alt}
label-connected = %local_ip%
format-disconnected =
;format-disconnected = <label-disconnected>
;format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${colors.foreground-alt}

[module/date]
type = internal/date
interval = 5
date =
date-alt = " %Y-%m-%d"
time = %I:%M %p
time-alt = %I:%M:%S %p
format-prefix-foreground = ${colors.foreground-alt}
label = %date% %time%

[module/pulseaudio]
type = internal/pulseaudio
format-volume = <label-volume> <bar-volume>
label-volume = Ô©Ĺ %percentage%%
label-volume-foreground = ${root.foreground}
label-muted = Ô™Ä
label-muted-foreground = ${colors.foreground}
bar-volume-width = 10
bar-volume-foreground-0 = ${colors.foreground}
bar-volume-foreground-1 = ${colors.foregorund}
bar-volume-foreground-2 = ${colors.foreground}
bar-volume-foreground-3 = ${colors.foreground}
bar-volume-foreground-4 = ${colors.foregorund}
bar-volume-foreground-5 = ${colors.foregorund}
bar-volume-foreground-6 = ${colors.foreground}
bar-volume-gradient = false
bar-volume-indicator = 
bar-volume-indicator-font = 2
bar-volume-fill = ÔĪĘ
bar-volume-fill-font = 2
bar-volume-empty = Ôõó
bar-volume-empty-font = 2
bar-volume-empty-foreground = ${colors.foreground-alt}

[module/battery0]
type = internal/battery
battery = BAT0
adapter = AC
full-at = 98
format-charging = BAT0+ <label-charging>
format-discharging = BAT0- <label-discharging>
format-full-prefix = "BAT0 "

[module/battery1]
type = internal/battery
battery = BAT1
adapter = AC
full-at = 98
format-charging = BAT1+ <label-charging>
format-discharging = BAT1- <label-discharging>
format-full-prefix = "BAT1 "

[module/temperature]
type = internal/temperature
thermal-zone = 0
warn-temperature = 60
format = TEMP <label>
format-warn = TEAMP! <label-warn>
label = %temperature-c%
label-warn = %temperature-c%

[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over
pseudo-transparency = true

[global/wm]
margin-top = 0
margin-bottom = 0

