super + Return
	urxvt

super + Escape
	pkill -USR1 -x sxhkd

super + Tab
	rofi -show run -display-run ">_"

super + shift + {f, t, w}
	{firefox, thunar, libreoffice --writer}

{XF86AudioRaiseVolume}
	pactl set-sink-volume 0 +5%

{XF86AudioLowerVolume}
	pactl set-sink-volume 0 -5%

{XF86AudioMute}
	pactl set-sink-mute 0 toggle
